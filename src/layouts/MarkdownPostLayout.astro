---
// 导入你之前写的通用布局
import BaseLayout from './BaseLayout.astro'; 

const { frontmatter } = Astro.props;
---

<BaseLayout pageTitle={frontmatter.title}>
  <article class="post-content">
    <h1>{frontmatter.title}</h1>
    <p class="metadata">
      <strong>作者：</strong>{frontmatter.author} | 
      <strong>发布日期：</strong>{frontmatter.pubDate.toString().slice(0,10)}
    </p>
    <hr />
    
    <slot />
  </article>
</BaseLayout>

<style>
  /* 你可以专门为博客文章添加一些样式 */
  .post-content {
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .metadata {
    color: #666;
  }
</style>